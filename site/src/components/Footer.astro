---
import logo from '../assets/logo.svg';
---

<footer class="footer">
	<a class="brand mini" href="/" aria-label="APIEase home">
		<img class="logo" src={logo.src} alt="APIEase logo" />
	</a>
	<div class="footer-links">
		<a href="https://docs.apiease.com" target="_blank" rel="noreferrer">Docs</a>
		<a href="https://apps.shopify.com/apiease-admin" target="_blank" rel="noreferrer">Shopify app</a>
		<a href="https://github.com/APIEase/apiease-cli" target="_blank" rel="noreferrer">apiease-cli</a>
		<a href="https://github.com/APIEase/apiease-examples" target="_blank" rel="noreferrer">apiease-examples</a>
		<a href="https://github.com/APIEase/apiease-template" target="_blank" rel="noreferrer">apiease-template</a>
		<a href="/privacy-policy">Privacy Policy</a>
	</div>
	<div class="footer-social" aria-label="APIEase social links">
		<a
			class="social-link"
			href="https://www.linkedin.com/company/apiease"
			target="_blank"
			rel="noreferrer"
			aria-label="APIEase on LinkedIn"
		>
			<svg class="social-icon" viewBox="0 0 24 24" aria-hidden="true">
				<path
					fill="currentColor"
					d="M20.447 20.452h-3.554v-5.569c0-1.328-.026-3.037-1.849-3.037-1.851 0-2.134 1.445-2.134 2.939v5.667H9.356V9h3.414v1.561h.049c.476-.9 1.637-1.849 3.369-1.849 3.604 0 4.27 2.372 4.27 5.455v6.285zM5.337 7.433a2.062 2.062 0 0 1-2.062-2.065 2.063 2.063 0 1 1 4.126 0 2.063 2.063 0 0 1-2.064 2.065zM7.119 20.452H3.554V9h3.565v11.452zM22.225 0H1.771C.792 0 0 .77 0 1.723v20.555C0 23.23.792 24 1.771 24h20.451C23.2 24 24 23.23 24 22.278V1.723C24 .77 23.2 0 22.222 0h.003z"
				/>
			</svg>
		</a>
		<a
			class="social-link"
			href="https://www.facebook.com/APIEasePlatform"
			target="_blank"
			rel="noreferrer"
			aria-label="APIEase on Facebook"
		>
			<svg class="social-icon" viewBox="0 0 24 24" aria-hidden="true">
				<path
					fill="currentColor"
					d="M22.675 0h-21.35C.597 0 0 .6 0 1.338v21.324C0 23.402.597 24 1.325 24h11.495v-9.294H9.692v-3.622h3.128V8.414c0-3.1 1.894-4.788 4.659-4.788 1.325 0 2.464.099 2.797.143v3.243l-1.92.001c-1.505 0-1.797.716-1.797 1.768v2.319h3.587l-.467 3.622h-3.12V24h6.116C23.403 24 24 23.402 24 22.662V1.338C24 .6 23.403 0 22.675 0Z"
				/>
			</svg>
		</a>
		<a
			class="social-link"
			href="https://github.com/APIEase"
			target="_blank"
			rel="noreferrer"
			aria-label="APIEase on GitHub"
		>
			<svg class="social-icon" viewBox="0 0 24 24" aria-hidden="true">
				<path
					fill="currentColor"
					d="M12 .297C5.373.297 0 5.67 0 12.297c0 5.303 3.438 9.8 8.205 11.387.6.111.82-.261.82-.58 0-.287-.011-1.244-.016-2.256-3.338.726-4.042-1.416-4.042-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.085 1.839 1.237 1.839 1.237 1.07 1.835 2.809 1.305 3.495.998.108-.775.419-1.305.762-1.605-2.665-.303-5.467-1.333-5.467-5.932 0-1.31.469-2.381 1.236-3.221-.124-.303-.535-1.523.117-3.176 0 0 1.008-.322 3.301 1.23A11.51 11.51 0 0 1 12 6.073c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.873.119 3.176.769.84 1.235 1.911 1.235 3.221 0 4.61-2.807 5.625-5.479 5.922.43.371.814 1.102.814 2.222 0 1.606-.015 2.9-.015 3.293 0 .322.216.697.825.579C20.565 22.092 24 17.597 24 12.297 24 5.67 18.627.297 12 .297z"
				/>
			</svg>
		</a>
	</div>
</footer>
