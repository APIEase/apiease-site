---
import Layout from '../layouts/Layout.astro';
import Backdrop from '../components/Backdrop.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const capabilityGroups = [
	{
		key: 'requests',
		title: 'Requests',
		note: 'All requests and logic run server side, with API keys and sensitive data kept secure and never exposed to the storefront or external callers.',
		items: [
			{
				title: 'HTTP Requests',
				copy: 'Call external APIs with server side execution, including headers, bodies, and secure credentials handled by APIEase.',
			},
			{
				title: 'Flow Requests',
				copy: 'Trigger Shopify Flow from APIEase and pass structured data into workflows for downstream logic and actions.',
			},
			{
				title: 'Liquid Requests',
				copy: 'Orchestrate multiple requests and transform data using Liquid that runs inside APIEase.',
			},
			{
				title: 'System Requests',
				copy: 'Run internal APIEase operations such as managing variables and system state without calling external APIs.',
			},
		],
	},
	{
		key: 'components',
		title: 'Components',
		items: [
			{
				title: 'Widgets',
				copy: 'Render dynamic storefront components powered by APIEase requests without exposing backend logic or credentials.',
			},
			{
				title: 'Functions',
				copy: 'Reuse modular Liquid logic across requests to simplify complex workflows and storefront processes.',
			},
			{
				title: 'Variables',
				copy: 'Store persistent values used across requests and workflows, including sensitive backend only data.',
			},
		],
	},
];

const steps = [
	{
		title: 'Define your system',
		copy: 'Create requests, widgets, functions, and variables that define how your integrations and workflows should behave.',
	},
	{
		title: 'Trigger from any source',
		copy: 'Run the same system from webhooks, schedules, proxy endpoints, storefront calls, Shopify Flow, remote clients, or manually.',
	},
	{
		title: 'APIEase runs and responds',
		copy: 'The managed runtime executes your logic server side, injects secure parameters, handles concurrency and tracking, and returns results to the caller.',
	},
];

const buildPaths = [
	{
		key: 'admin',
		title: 'Build in the admin',
		copy: 'Create and manage requests, widgets, functions, and variables directly in APIEase with a guided interface.',
	},
	{
		key: 'cli',
		title: 'Develop locally',
		copy: 'Use apiease-cli and templates to define systems as code, version them, and push them to APIEase.',
	},
	{
		key: 'ai',
		title: 'Build with AI assistance',
		copy: 'Use AI agents to assist, generate, and configure APIEase systems, whether working alongside you in development or operating autonomously.',
	},
];

const useCases = [
	{
		key: 'storefront',
		title: 'Dynamic storefront experiences',
		copy: 'Display real time data from external APIs directly in your storefront using widgets powered by APIEase requests.',
	},
	{
		key: 'sync',
		title: 'Inventory and data synchronization',
		copy: 'Sync products, inventory, and data between Shopify and external systems using scheduled or event driven workflows.',
	},
	{
		key: 'integrations',
		title: 'External system integrations',
		copy: 'Connect your store to ERPs, CRMs, and third party services by orchestrating API calls and transforming data with Liquid.',
	},
	{
		key: 'automation',
		title: 'Automated workflows',
		copy: 'Trigger multi step processes from webhooks, Shopify Flow, or storefront actions to automate complex business logic.',
	},
	{
		key: 'security',
		title: 'Secure API access from the storefront',
		copy: 'Call external APIs from your storefront without exposing API keys by routing requests through APIEase.',
	},
	{
		key: 'ai',
		title: 'AI assisted system creation',
		copy: 'Use AI agents to design and configure integrations and workflows that run automatically in APIEase.',
	},
];
---

<Layout>
	<div class="page">
		<Backdrop />

		<Header />

		<main>
			<section class="hero">
				<h1>The API Integration And Automation Runtime</h1>
				<p class="lede">
					Build and run API integrations, workflows, and storefront logic automatically,
					without building or maintaining a backend.
				</p>
			</section>

			<section id="product" class="panel">
				<div class="panel-heading">
					<div class="kicker">What it does</div>
					<h2>Define your integrations once. APIEase runs them automatically.</h2>
					<p>APIEase executes HTTP, Flow, Liquid, and System requests in a managed
						runtime, so the logic you define is reusable, secure, and runs
						automatically across your integrations and workflows.
					</p>
					<br/>
					<p>
						Combine requests with widgets, functions, and variables to build
						systems that connect your storefront, external APIs, and backend processes.
					</p>
				</div>
				<div class="capability-groups">
					{capabilityGroups.map((group) => (
						<div class={`capability-group capability-group-${group.key}`}>
							<div class="group-title">{group.title}</div>
							<div class="capabilities">
								{group.items.map((item) => (
									<div class="card">
										<div class="card-copy">
											<div class="card-heading">
												<div class={`icon icon-${group.key}`}>
													{group.key === 'requests' ? (
														<svg viewBox="0 0 24 24" aria-hidden="true" class="icon-svg">
															<path d="M4 11h9V8l7 4-7 4v-3H4z" fill="currentColor" />
														</svg>
													) : (
														<svg viewBox="0 0 24 24" aria-hidden="true" class="icon-svg">
															<rect x="4" y="4" width="7" height="7" rx="1.5" fill="currentColor" />
															<rect x="13" y="4" width="7" height="7" rx="1.5" fill="currentColor" />
															<rect x="4" y="13" width="7" height="7" rx="1.5" fill="currentColor" />
															<rect x="13" y="13" width="7" height="7" rx="1.5" fill="currentColor" />
														</svg>
													)}
												</div>
												<h3>{item.title}</h3>
											</div>
											<p>{item.copy}</p>
										</div>
									</div>
								))}
							</div>
							{group.note && <p class="capabilities-note">{group.note}</p>}
						</div>
					))}
				</div>
			</section>

			<section id="workflow" class="panel steps">
				<div class="panel-heading">
					<div class="kicker">How it works</div>
					<h2>Define once. Trigger anywhere.</h2>
					<p>Configure your integrations, workflows, and storefront logic once. APIEase runs them wherever they&rsquo;re needed without building a new backend each time.</p>
				</div>
				<div class="step-grid">
					{steps.map((step, index) => (
						<div class="step-card">
							<div class="step-index">Step {index + 1}</div>
							<h3>{step.title}</h3>
							<p>{step.copy}</p>
						</div>
					))}
				</div>
				<div class="trigger-block">
					<div class="trigger-title">Triggers you can turn on day one</div>
					<div class="trigger-tags">
						<span class="tag">Webhooks</span>
						<span class="tag">Schedules</span>
						<span class="tag">Proxy endpoints</span>
						<span class="tag">Storefront calls</span>
						<span class="tag">Shopify Flow</span>
						<span class="tag">Remote clients</span>
						<span class="tag">Manual runs</span>
					</div>
				</div>
			</section>

			<section id="creation" class="panel build-paths">
				<div class="panel-heading">
					<div class="kicker">Create integrations your way</div>
					<h2>Build manually, develop locally, or let AI build it for you.</h2>
					<p>
						APIEase gives you multiple ways to define your integrations and automation
						systems. No matter how you build them, they all run in the same managed
						runtime.
					</p>
				</div>
				<div class="build-path-grid">
					{buildPaths.map((path) => (
						<div class={`build-path-card build-path-card-${path.key}`}>
							<div class="build-path-copy">
								<div class="build-path-heading">
									<div class="build-path-icon">
										{path.key === 'admin' ? (
											<svg viewBox="0 0 24 24" aria-hidden="true" class="icon-svg">
												<rect x="4" y="5" width="16" height="14" rx="2.5" fill="none" stroke="currentColor" stroke-width="2" />
												<path d="M4 10h16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
												<circle cx="8" cy="7.5" r="1" fill="currentColor" />
												<circle cx="11" cy="7.5" r="1" fill="currentColor" />
												<path d="M8 14h4m-4 3h8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
											</svg>
										) : path.key === 'cli' ? (
											<svg viewBox="0 0 24 24" aria-hidden="true" class="icon-svg">
												<rect x="3.5" y="5" width="17" height="14" rx="2.5" fill="none" stroke="currentColor" stroke-width="2" />
												<path d="m8 10 3 2-3 2m5 0h3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
											</svg>
										) : (
											<svg viewBox="0 0 24 24" aria-hidden="true" class="icon-svg">
												<path d="M12 3.5 13.9 8l4.6.4-3.5 3 1.1 4.5-4.1-2.5-4.1 2.5 1.1-4.5-3.5-3L10.1 8Z" fill="currentColor" />
												<circle cx="18.5" cy="6" r="1.5" fill="currentColor" opacity="0.8" />
												<circle cx="6" cy="17.5" r="1.2" fill="currentColor" opacity="0.8" />
											</svg>
										)}
									</div>
									<h3>{path.title}</h3>
								</div>
								<p>{path.copy}</p>
							</div>
						</div>
					))}
				</div>
				<div class="build-path-footer">
					<span>No matter how you build it, APIEase runs it.</span>
				</div>
			</section>

			<section id="use-cases" class="panel use-cases">
				<div class="panel-heading">
					<div class="kicker">Use cases</div>
					<h2>Build systems that connect your store to anything</h2>
					<p>
						From storefront experiences to backend automation, APIEase lets you build
						systems that integrate external APIs, Shopify data, and your own business
						logic.
					</p>
				</div>
				<div class="use-case-grid">
					{useCases.map((item) => (
						<div class="use-case-card build-path-card">
							<div class="build-path-copy">
								<div class="build-path-heading">
									<div class="build-path-icon">
										{item.key === 'storefront' ? (
											<svg viewBox="0 0 24 24" aria-hidden="true" class="icon-svg">
												<rect x="4" y="5" width="16" height="14" rx="2.5" fill="none" stroke="currentColor" stroke-width="2" />
												<path d="M8 9h8M8 13h5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
											</svg>
										) : item.key === 'sync' ? (
											<svg viewBox="0 0 24 24" aria-hidden="true" class="icon-svg">
												<path d="M7 7h9l-2-2m2 2-2 2M17 17H8l2 2m-2-2 2-2" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
											</svg>
										) : item.key === 'integrations' ? (
											<svg viewBox="0 0 24 24" aria-hidden="true" class="icon-svg">
												<circle cx="7" cy="12" r="2.5" fill="currentColor" />
												<circle cx="17" cy="7" r="2.5" fill="currentColor" />
												<circle cx="17" cy="17" r="2.5" fill="currentColor" />
												<path d="M9.4 10.8 14.6 8.2M9.4 13.2l5.2 2.6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
											</svg>
										) : item.key === 'automation' ? (
											<svg viewBox="0 0 24 24" aria-hidden="true" class="icon-svg">
												<path d="M6 6h12v4H6zm0 8h5v4H6zm7 0h5v4h-5z" fill="currentColor" />
											</svg>
										) : item.key === 'security' ? (
											<svg viewBox="0 0 24 24" aria-hidden="true" class="icon-svg">
												<path d="M12 3 5 6v5c0 4.4 2.9 8.4 7 10 4.1-1.6 7-5.6 7-10V6z" fill="currentColor" />
												<path d="M10 12.5 11.5 14 14.5 11" fill="none" stroke="#0f1422" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
											</svg>
										) : (
											<svg viewBox="0 0 24 24" aria-hidden="true" class="icon-svg">
												<path d="M12 3.5 13.9 8l4.6.4-3.5 3 1.1 4.5-4.1-2.5-4.1 2.5 1.1-4.5-3.5-3L10.1 8Z" fill="currentColor" />
											</svg>
										)}
									</div>
									<h3>{item.title}</h3>
								</div>
								<p>{item.copy}</p>
							</div>
						</div>
					))}
				</div>
				<div class="use-case-footer">
					<span>From simple integrations to fully automated systems, APIEase runs everything in one place.</span>
				</div>
			</section>

			<section id="get-started" class="panel cta-panel">
				<div class="cta-panel-inner">
					<div class="kicker">Get started</div>
					<h2>Build the system. APIEase runs it.</h2>
					<p>
						Create API integrations, workflows, and storefront systems without
						building or maintaining a custom backend. Start in the admin, develop
						locally, or work with AI to define what runs.
					</p>
					<div class="cta-panel-actions">
						<a
							class="pill primary"
							href="https://apps.shopify.com/apiease-admin"
							target="_blank"
							rel="noreferrer"
						>
							Install APIEase
						</a>
						<a
							class="pill ghost"
							href="https://docs.apiease.com/"
							target="_blank"
							rel="noreferrer"
						>
							View Documentation
						</a>
					</div>
					<div class="cta-panel-note">Define once. Trigger anywhere.</div>
				</div>
			</section>
		</main>

		<Footer />
	</div>
</Layout>

<style>
	.tagline {
		font-size: 12px;
		color: var(--muted);
	}

	.hero {
		margin: 110px 0 70px;
		max-width: 880px;
	}

	.eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 8px 12px;
		border: 1px solid var(--border);
		border-radius: 999px;
		color: var(--muted);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		font-size: 12px;
	}

	h1 {
		font-size: clamp(44px, 6vw, 68px);
		margin: 18px 0 12px;
		line-height: 1.05;
		font-family: 'Space Grotesk', 'Plus Jakarta Sans', sans-serif;
		color: #f6f8ff;
	}

	.lede {
		font-size: 18px;
		line-height: 1.7;
		color: #c6d4f0;
		max-width: 720px;
		margin: 0 0 24px;
	}

	.panel {
		margin: 60px 0;
		padding: 26px;
		border-radius: 24px;
		background: var(--panel);
		border: 1px solid var(--border);
		box-shadow: 0 18px 60px rgba(0, 0, 0, 0.35);
	}

	.panel-heading {
		max-width: 720px;
	}

	.kicker {
		color: var(--primary);
		font-weight: 700;
		letter-spacing: 0.1em;
		font-size: 12px;
		text-transform: uppercase;
		margin-bottom: 8px;
	}

	h2 {
		font-size: 34px;
		margin: 0 0 10px;
		color: #f6f8ff;
	}

	p {
		color: #bdc9e3;
		font-size: 16px;
		line-height: 1.7;
		margin: 0;
	}

	.capability-groups {
		display: grid;
		gap: 24px;
		margin-top: 24px;
	}

	.capability-group {
		display: grid;
		gap: 12px;
		padding: 18px;
		border-radius: 18px;
		border: 1px solid rgba(255, 255, 255, 0.08);
		background: rgba(255, 255, 255, 0.015);
	}

	.group-title {
		font-size: 13px;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--primary);
	}

	.capabilities {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 16px;
	}

	.capabilities .card {
		padding: 18px;
		border-radius: 16px;
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid var(--border);
		display: block;
	}

	.card-copy {
		display: flex;
		flex-direction: column;
		gap: 10px;
	}

	.card-heading {
		display: grid;
		grid-template-columns: 36px minmax(0, 1fr);
		align-items: center;
		gap: 12px;
	}

	.card-heading h3 {
		margin: 0;
	}

	.capabilities-note {
		margin-top: 18px;
		max-width: 760px;
		color: #c6d4f0;
	}

	.icon {
		width: 36px;
		height: 36px;
		border-radius: 10px;
		background: linear-gradient(135deg, var(--primary), var(--accent-3));
		display: grid;
		place-items: center;
		color: #f6f8ff;
		font-weight: 700;
		flex-shrink: 0;
		box-shadow: 0 8px 18px rgba(36, 149, 219, 0.18);
	}

	.icon-svg {
		width: 20px;
		height: 20px;
		display: block;
	}

	h3 {
		margin: 0 0 8px;
		color: #f6f8ff;
		font-size: 20px;
	}

	.steps .step-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 16px;
		margin-top: 24px;
	}

	.build-path-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 20px;
		margin-top: 28px;
	}

	.build-path-card {
		padding: 22px;
		border-radius: 18px;
		border: 1px solid var(--border);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.015)),
			rgba(255, 255, 255, 0.02);
		display: grid;
		gap: 18px;
		min-height: 220px;
		transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
	}

	.build-path-icon {
		width: 44px;
		height: 44px;
		border-radius: 12px;
		background: linear-gradient(135deg, var(--primary), var(--accent-3));
		display: grid;
		place-items: center;
		color: #f6f8ff;
		box-shadow: 0 10px 24px rgba(36, 149, 219, 0.22);
	}

	.build-path-copy {
		display: grid;
		gap: 8px;
	}

	.build-path-heading {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.build-path-copy h3 {
		margin-bottom: 0;
	}

	.build-path-copy p {
		color: #c6d4f0;
	}

	@media (hover: hover) {
		.build-path-card:hover {
			transform: translateY(-2px);
			border-color: rgba(255, 255, 255, 0.16);
			box-shadow: 0 16px 36px rgba(0, 0, 0, 0.22);
		}
	}

	.build-path-footer {
		margin-top: 28px;
		padding-top: 8px;
		display: flex;
		justify-content: center;
	}

	.build-path-footer span {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 12px 18px;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.1);
		background: rgba(255, 255, 255, 0.025);
		font-size: 17px;
		font-weight: 700;
		color: #f6f8ff;
		text-align: center;
	}

	.use-case-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 20px;
		margin-top: 28px;
	}

	.use-case-footer {
		margin-top: 28px;
		padding-top: 8px;
		display: flex;
		justify-content: center;
	}

	.use-case-footer span {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 12px 18px;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.1);
		background: rgba(255, 255, 255, 0.025);
		font-size: 17px;
		font-weight: 700;
		color: #f6f8ff;
		text-align: center;
	}

	.cta-panel {
		padding: 34px 26px;
	}

	.cta-panel-inner {
		max-width: 760px;
		margin: 0 auto;
		text-align: center;
	}

	.cta-panel-actions {
		display: flex;
		justify-content: center;
		gap: 12px;
		flex-wrap: wrap;
		margin-top: 24px;
	}

	.cta-panel-note {
		margin-top: 18px;
		color: #dce5f5;
		font-weight: 600;
		font-size: 15px;
	}

	.step-card {
		padding: 18px;
		border-radius: 16px;
		border: 1px solid var(--border);
		background: rgba(255, 255, 255, 0.015);
	}

	.step-index {
		font-size: 13px;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		color: var(--primary);
		margin-bottom: 10px;
		font-weight: 700;
	}

	.trigger-block {
		margin-top: 28px;
		padding: 18px;
		border-radius: 16px;
		border: 1px solid var(--border);
		background: rgba(255, 255, 255, 0.02);
	}

	.trigger-title {
		font-weight: 700;
		color: #f6f8ff;
		margin-bottom: 10px;
		font-size: 16px;
	}

	.trigger-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
	}

	.tag {
		display: inline-flex;
		align-items: center;
		padding: 7px 12px;
		border-radius: 999px;
		border: 1px solid var(--border);
		color: var(--muted);
		background: rgba(255, 255, 255, 0.03);
		font-weight: 600;
		font-size: 14px;
		letter-spacing: 0.01em;
	}

	.testimonial {
		display: grid;
		grid-template-columns: 2fr 1.2fr;
		gap: 20px;
		align-items: center;
	}

